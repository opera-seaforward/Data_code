# Exemple .env pour CMEMS/GLORYS12 uniquement
DATA_SOURCE=cmems

# Dataset CMEMS
CMEMS_DATASET=cmems_mod_glo_phy_anfc_0.083deg_P1D-m

# Variables separees par virgules
CMEMS_VARIABLES=uo,vo,thetao,so

# Domaine geographique
CMEMS_LONGITUDES=-10,12
CMEMS_LATITUDES=-6,7

# Periode (YYYY-MM-DD)
CMEMS_START_DATE=2020-01-01
CMEMS_END_DATE=2020-01-03

# Profondeur min,max
CMEMS_DEPTH=0,500

# Dossier de sortie (chemin relatif)
CMEMS_OUTPUT_DIR=data_copernicus

# Identifiants CMEMS
CMEMS_USERNAME=votre_user
CMEMS_PASSWORD=votre_password
